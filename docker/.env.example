# ============================
# SSKit Docker 部署配置
# ============================

# ---------- 应用配置 ----------
# 镜像版本标签
TAG=v1.0.2
# Nginx HTTPS 端口（对外）
NGINX_PORT=57701
# JVM 参数
JAVA_OPTS=-Xms1g -Xmx2g -XX:+UseG1GC

# ---------- MySQL 配置 ----------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB_NAME=sskit_kit
MYSQL_USERNAME=sskit
MYSQL_PASSWORD=Sskit@123456
MYSQL_ROOT_PASSWORD=Sskit@123456

# ---------- Redis 配置 ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=Sskit@123456
